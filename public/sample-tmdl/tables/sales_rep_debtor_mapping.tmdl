table sales_rep_debtor_mapping

	column Customer_Code
		dataType: string
		sourceColumn: Customer_Code

	column SalesmanNo
		dataType: string
		sourceColumn: SalesmanNo

	column UserUPN
		dataType: string
		sourceColumn: UserUPN

	column MappingType
		dataType: string
